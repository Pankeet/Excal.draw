{
  "name": "excal.draw",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run dev",
    "dev": "concurrently -n DB,HTTP,WS,FE -c green,blue,yellow,magenta \"pnpm --filter @repo/db-local@1.0.0 dev\" \"pnpm --filter http-server dev\" \"pnpm --filter ws-server dev\" \"pnpm --filter excal_fe dev\"",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "22.19.17"
    }
  }
}
