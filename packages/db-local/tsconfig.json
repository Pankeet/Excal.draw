{
  "compilerOptions": {
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "exclude": ["node_modules","dist"]
}